# =====================================================================
# Recruiting Atelier — backend env
# Copy this file to .env and fill in the values you need.
#
# .env is gitignored. Never commit real keys.
# =====================================================================

# --- LLM provider --------------------------------------------------
# Active chat + embedding provider. Override per-run from /settings.
LLM_CHAT_PROVIDER=anthropic
LLM_EMBED_PROVIDER=openai

# Provider credentials — set the ones you intend to use; leave the
# rest empty.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_API_KEY=
OLLAMA_API_KEY=ollama

# --- Observability (optional) --------------------------------------
# If unset, traces fall back to in-memory + print.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Runtime ports / CORS ------------------------------------------
MCP_PORT=8000
# 8001 often collides with a local Chroma server — using 8011 by default.
API_PORT=8011
FRONTEND_ORIGIN=http://localhost:3000

# Hard upper bound on the supervisor's ReAct iterations
MAX_ITERATIONS=10
# Default shortlist size (overridable per run)
TOP_N=3

# --- Knowledge base -------------------------------------------------
# In-memory KB ceiling (bytes)
KB_MAX_BYTES=536870912
# Embedding backend for the KB:
#   local    — Chroma's bundled all-MiniLM-L6-v2 (default; offline, no API key)
#   provider — use the LLM_EMBED_PROVIDER above
KB_EMBED_BACKEND=local

# --- Persistent paths ----------------------------------------------
# All of these are auto-created at runtime; just override paths if you want.
SHORTLIST_CHROMA_PATH=./.chroma-shortlists
# SCORING_CONFIG_PATH=./.scoring-config.json   # Diya's weights (Settings > II)
# DEMO_CONFIG_PATH=./.demo-config.json         # Demo pacing (Settings > III)
# SEEN_RESUMES_PATH=./.seen-resumes.json       # Kavya's dedup store

# --- Misc -----------------------------------------------------------
# Silence chromadb posthog telemetry warnings
ANONYMIZED_TELEMETRY=False
