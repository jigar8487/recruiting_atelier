# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
*.egg-info/
.pytest_cache/

# Node
node_modules/
.next/
out/
*.log

# Env — ignore every variant. Only *.example may be committed.
.env
.env.*
!.env.example
!.env.*.example
*.env
*.env.local
*.env.bak
*.env.backup
*.env.save
*.env.old
backend/.env
backend/.env.*
!backend/.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example

# Stray backups / editor swap files anywhere in the tree
*.bak
*.backup
*.orig
*.save
*.swp
*.swo
*~

# Data — runtime state, never commit
.chroma-shortlists/
.chroma/
.ollama/
.scoring-config.json
.demo-config.json
.seen-resumes.json
backend/.chroma-shortlists/
backend/.scoring-config.json
backend/.demo-config.json
backend/.seen-resumes.json
.ollama/

